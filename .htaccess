# =============================================================================
# .htaccess - 301 Redirects for JK Executive Chauffeurs
# =============================================================================
# This file handles permanent (301) redirects from old URLs to new URLs.
# Place this file in the root directory of your Apache web server.
# =============================================================================

# Enable Rewrite Engine
<IfModule mod_rewrite.c>
    RewriteEngine On

    # =============================================================================
    # SERVICES REDIRECTS
    # =============================================================================

    # Corporate Chauffeur Service
